# ===========================================
# AWS Solutions Architect - Associate Project
# Root .gitignore
# ===========================================

# --- Terraform ---
*.tfstate
*.tfstate.*
*.tfstate.backup
*.tfvars
!*.tfvars.example
!terraform.tfvars.example
.terraform/
tfplan
*.tfplan

# --- Lambda / Python ---
lambda_functions/*.zip
*.py[cod]
*$py.class
__pycache__/
*.pyc
.Python
venv/
env/
.venv/

# --- Node.js (if any frontend build) ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- IDE & Editors ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- OS ---
.DS_Store
Thumbs.db
Desktop.ini

# --- Logs & Temp ---
*.log
*.tmp
*.temp
*.bak

# --- AWS / Local ---
.aws/
*.pem

# --- Environment ---
.env
.env.local
.env.*.local
